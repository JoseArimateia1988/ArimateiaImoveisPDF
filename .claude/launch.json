{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "runtimeArgs": ["-e", "const h=require('http'),f=require('fs'),p=require('path');h.createServer((q,r)=>{let fp=p.join('/Users/camis/PDF Im\\u00f3veis/frontend',q.url==='/'?'index.html':q.url);try{r.writeHead(200,{'Content-Type':'text/html; charset=utf-8'});f.createReadStream(fp).pipe(r);}catch(e){r.writeHead(404);r.end();}}).listen(3000,()=>console.log('frontend em 3000'));"],
      "port": 3000
    }
  ]
}
